rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default safety deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for MuroPost collection
    match /muro_posts/{postId} {
      // Anyone can read posts (guests/visitors)
      allow read: if true;
      
      // Anyone can create a post, as long as it starts with 0 likes and the document ID matches the field ID
      allow create: if postId != null 
                    && request.resource.data.id == postId
                    && (request.resource.data.likes == 0 || request.resource.data.likes == 0.0);
      
      // Anyone can update likes (incrementing/decrementing), but cannot alter the document ID
      allow update: if request.resource.data.id == resource.data.id;
    }

    // Rules for mural_solicitudes collection
    match /mural_solicitudes/{solicitudeId} {
      // Anyone can read and create solicitudes de venta
      allow read, create: if true;
      
      // Admin/VIP users can update/delete client submissions
      allow update, delete: if true;
    }
  }
}
